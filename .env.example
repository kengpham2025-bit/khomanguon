# Turso Database (libSQL)
# Get your connection URL from https://turso.tech or run: turso db show <db-name>
TURSO_DATABASE_URL=libsql://your-database-url.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Local development SQLite (for dev without Turso cloud)
# Format: file:local_dev.db or file:./local_dev.db
TURSO_LOCAL_URL=file:local_dev.db

# Convex (commented out - using Turso instead)
# NEXT_PUBLIC_CONVEX_URL=https://your-convex-project.convex.cloud

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
# Groq AI API (for news rewriting)
GROQ_API_KEY=your_groq_api_key

# Resend Email API (for OTP)
RESEND_API_KEY=your_resend_api_key

# hCaptcha (replacing Cloudflare Turnstile)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key

# PayOS Payment
NEXT_PUBLIC_PAYOS_CLIENT_ID=your_payos_client_id
PAYCROS_BANK_CODE=your_paycos_bank_code
PAYCROS_ACCOUNT_NUMBER=your_paycos_account_number
PAYCROS_ACCOUNT_NAME=your_paycos_account_name
PAYCROS_API_KEY=your_paycos_api_key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
