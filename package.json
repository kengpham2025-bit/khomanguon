{
  "name": "khomanguon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const p of ['.next','node_modules/.cache']) { try { fs.rmSync(p, { recursive: true, force: true }); } catch (_) {} }\"",
    "dev": "cross-env NEXT_TRACE_SPAN_THRESHOLD_MS=999999999 next dev",
    "build": "cross-env NEXT_TRACE_SPAN_THRESHOLD_MS=999999999 next build",
    "start": "next start",
    "lint": "eslint",
    "pages:build": "cross-env NEXT_TRACE_SPAN_THRESHOLD_MS=999999999 next build && npx @opennextjs/cloudflare build",
    "pages:preview": "wrangler pages dev .open-next/cloudflare",
    "pages:deploy": "wrangler pages deploy .open-next/cloudflare",
    "d1:migrate": "wrangler d1 execute khomanguonnew --remote --file=./schema.sql",
    "d1:migrate:local": "wrangler d1 execute khomanguonnew --local --file=./schema.sql"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.1.0",
    "@opennextjs/cloudflare": "1.18.0",
    "@payos/node": "^2.0.5",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "jose": "^5.9.6",
    "lucide-react": "^0.468.0",
    "next": "~15.5.10",
    "nextjs-toploader": "^3.9.17",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@ast-grep/napi-linux-x64-gnu": "0.40.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^9",
    "eslint-config-next": "~15.5.10",
    "open-next": "^3.1.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "wrangler": "^4.77.0"
  }
}
